# Supabase
# Used by the Python API for saved companies, sources, and reports.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend -> Python API
PYTHON_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_PYTHON_API_URL=http://127.0.0.1:8000
CORS_ORIGIN=http://localhost:3000

# AI providers
# OpenAI is the first provider we will wire for extraction and summarization.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# Web search providers
# Tavily is used by the Python API. If empty, local mock search is used.
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=

# Observability
# Langfuse can stay empty until we start tracing real AI/search calls.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
